model NotificationToggle {
    id                      String  @id @default(uuid())
    email                   Boolean @default(true)
    userUpdates             Boolean @default(true)
    serviceCreate           Boolean @default(true)
    review                  Boolean @default(true)
    post                    Boolean @default(true)
    message                 Boolean @default(true)
    inquiry                 Boolean @default(true)
    userRegistration        Boolean @default(true)
    service                 Boolean @default(true)
    follow                  Boolean @default(true)
    orderUpdate             Boolean @default(true)
    uploadProof             Boolean @default(true)
    paymentReminder         Boolean @default(true)
    newOrder                Boolean @default(true)
    serviceRequestAccepted  Boolean @default(true)
    serviceRequestRejected  Boolean @default(true)
    serviceRequestCancelled Boolean @default(true)
    paymentSuccessful       Boolean @default(true)
    paymentFailed           Boolean @default(true)
    inquiryResponse         Boolean @default(true)
    reviewReceived          Boolean @default(true)
    postCreated              Boolean @default(true)
    postLiked               Boolean @default(true)
    postCommented           Boolean @default(true)
    postShared              Boolean @default(true)
    postReplied             Boolean @default(true)
    donationReceived        Boolean @default(true)
    communityCreated        Boolean @default(true)
    communityJoined         Boolean @default(true)
    userId                  String
    user                    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("notification-toggle")
}
